# ===========================================
# Maison Éclat Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
# ------------------------------------------
# Option A: Local MongoDB
MONGO_URI=mongodb://localhost:27017/maison-eclat

# Option B: MongoDB Atlas (cloud) - replace with your connection string
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/maison-eclat?retryWrites=true&w=majority

# JWT (JSON Web Token) for Authentication
# ------------------------------------------
# This is a secret key used to sign tokens. Make it long and random!
# You can generate one by running: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# File Uploads
# ------------------------------------------
MAX_FILE_SIZE=5242880

# Signup email OTP
# ------------------------------------------
# Configure these to send real OTP emails. Without them, development OTPs are
# printed in the backend console instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM="Lumiere <your_email@example.com>"
# true prints OTPs in the backend console when SMTP fails; false forces real email sending.
EMAIL_FALLBACK_TO_CONSOLE=false
